{
  "name": "btcutil-js",
  "version": "0.1.0",
  "description": "Bitcoin utility library (btcutil) for JavaScript/TypeScript via WebAssembly",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate:wasm-exec": "node scripts/generate-wasm-exec.mjs",
    "build:wasm": "./build-wrapper.sh",
    "build:js": "npm run generate:wasm-exec && tsup && cp wasm-wrapper/btcutil.wasm dist/",
    "build": "npm run build:wasm && npm run build:js",
    "build:docs": "typedoc",
    "test": "node --test test/*.test.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "bitcoin",
    "btcutil",
    "base58",
    "bech32",
    "bip322",
    "hdkeychain",
    "psbt",
    "wasm",
    "webassembly",
    "txscript",
    "btcec",
    "btcd",
    "chaincfg",
    "schnorr",
    "ecdsa",
    "taproot"
  ],
  "author": "Oli <gugger@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guggero/btcutil-js.git"
  },
  "homepage": "https://github.com/guggero/btcutil-js",
  "bugs": {
    "url": "https://github.com/guggero/btcutil-js/issues"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.0.0"
  }
}
